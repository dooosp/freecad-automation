{
  "name": "freecad-automation",
  "version": "1.1.0",
  "description": "FreeCAD-backed automation pipeline for CAD, TechDraw, inspection, FEM, reports, and manufacturing-review artifacts",
  "homepage": "https://github.com/dooosp/freecad-automation#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dooosp/freecad-automation.git"
  },
  "bugs": {
    "url": "https://github.com/dooosp/freecad-automation/issues"
  },
  "imports": {
    "#i18n-contract": "./src/shared/i18n-contract.js"
  },
  "keywords": [
    "freecad",
    "cad",
    "techdraw",
    "fem",
    "manufacturing",
    "automation"
  ],
  "type": "module",
  "bin": {
    "fcad": "./bin/fcad.js",
    "mfg-agent": "./bin/fcad.js"
  },
  "scripts": {
    "check:runtime": "node scripts/check-runtime.js",
    "check:source-hygiene": "node scripts/check-source-tree-hygiene.js",
    "smoke:runtime": "npm run test:runtime-smoke",
    "test:node:contract": "node tests/run-node-lane.js contract",
    "test:node:integration": "node tests/run-node-lane.js integration",
    "test:studio-browser-smoke": "node tests/studio-shell-browser-smoke.test.js",
    "test:snapshots": "node tests/run-node-lane.js snapshots",
    "test:snapshots:update": "UPDATE_SNAPSHOTS=1 npm run test:snapshots",
    "test:runtime-smoke": "node tests/run-node-lane.js runtime-smoke",
    "test:py": "node scripts/run-pytest.js -q tests --ignore=tests/test_cli_runtime.py --ignore=tests/test_infotainment_draw_qa_regression.py --ignore=tests/test_infotainment_hole_dia_regression.py",
    "test:runtime:model": "node tests/test-runner.js --layers=model",
    "test:runtime:drawing": "node tests/test-runner.js --layers=drawing",
    "test:runtime:analysis": "node tests/test-runner.js --layers=analysis",
    "test:runtime:report": "node tests/test-runner.js --layers=report",
    "test:runtime:integration": "node tests/test-runner.js --layers=integration",
    "test:runtime:full": "node tests/test-runner.js --profile=full",
    "test:integration": "node tests/test-runner.js --layers=model,drawing,analysis,report,integration",
    "test:integration:full": "npm run test:runtime:full",
    "test:ci:hosted": "node scripts/run-test-suite.js hosted",
    "test:node:lite": "node scripts/run-test-suite.js node-lite",
    "test": "node scripts/run-test-suite.js default-node",
    "test:full": "npm run test:integration:full",
    "serve": "node bin/fcad.js serve",
    "serve:legacy": "node bin/serve-legacy.js"
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "ajv": "^8.18.0",
    "express": "^5.2.1",
    "smol-toml": "^1.3.1",
    "ws": "^8.19.0"
  }
}
