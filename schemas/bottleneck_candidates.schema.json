{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "bottleneck-candidates.schema.json",
  "title": "Bottleneck Candidates",
  "type": "object",
  "required": ["schema_version", "candidates"],
  "properties": {
    "schema_version": { "type": "string" },
    "candidates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "severity", "evidence"],
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "severity": { "type": "string" },
          "scope": { "type": "string" },
          "evidence": {
            "type": "array",
            "items": { "type": "string" }
          },
          "suggested_follow_up": { "type": "string" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
