{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://dooosp.github.io/freecad-automation/schemas/quality_risk.schema.json",
  "title": "Canonical Quality Risk",
  "type": "object",
  "required": [
    "schema_version",
    "artifact_type",
    "generated_at",
    "agent",
    "part",
    "summary",
    "quality_risks",
    "quality_gates",
    "warnings",
    "coverage",
    "confidence",
    "source_artifact_refs",
    "canonical_artifact",
    "contract"
  ],
  "properties": {
    "schema_version": { "const": "1.0" },
    "artifact_type": { "const": "quality_risk" },
    "generated_at": { "type": "string" },
    "agent": { "const": "quality_traceability" },
    "part": { "$ref": "c_artifact_common.schema.json#/definitions/partIdentity" },
    "summary": { "type": "object" },
    "warnings": { "$ref": "c_artifact_common.schema.json#/definitions/warningList" },
    "coverage": { "$ref": "c_artifact_common.schema.json#/definitions/coverageSummary" },
    "confidence": { "$ref": "c_artifact_common.schema.json#/definitions/confidenceSummary" },
    "source_artifact_refs": { "$ref": "c_artifact_common.schema.json#/definitions/sourceArtifactRefs" },
    "canonical_artifact": { "$ref": "c_artifact_common.schema.json#/definitions/canonicalArtifact" },
    "contract": { "$ref": "c_artifact_common.schema.json#/definitions/commandContract" },
    "critical_dimensions": { "type": "array", "items": { "type": "object" } },
    "inspection_required_points": { "type": "array", "items": { "type": "object" } },
    "traceability_summary": { "type": "object" },
    "quality_risks": { "type": "array", "items": { "type": "object" } },
    "quality_gates": { "type": "array", "items": { "type": "object" } },
    "evidence_pack": { "type": "object" }
  },
  "additionalProperties": true
}
