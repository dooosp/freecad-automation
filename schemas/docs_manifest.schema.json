{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://dooosp.github.io/freecad-automation/schemas/docs_manifest.schema.json",
  "title": "Canonical Standard Docs Manifest",
  "type": "object",
  "required": [
    "schema_version",
    "artifact_type",
    "workflow",
    "generated_at",
    "draft_notice",
    "part",
    "documents",
    "warnings",
    "coverage",
    "confidence",
    "source_artifact_refs",
    "canonical_artifact",
    "contract"
  ],
  "properties": {
    "schema_version": { "const": "1.0" },
    "artifact_type": { "const": "docs_manifest" },
    "workflow": { "const": "standard_docs_generation" },
    "generated_at": { "type": "string" },
    "draft_notice": { "type": "string" },
    "part": { "$ref": "c_artifact_common.schema.json#/definitions/partIdentity" },
    "warnings": { "$ref": "c_artifact_common.schema.json#/definitions/warningList" },
    "coverage": { "$ref": "c_artifact_common.schema.json#/definitions/coverageSummary" },
    "confidence": { "$ref": "c_artifact_common.schema.json#/definitions/confidenceSummary" },
    "source_artifact_refs": { "$ref": "c_artifact_common.schema.json#/definitions/sourceArtifactRefs" },
    "canonical_artifact": { "$ref": "c_artifact_common.schema.json#/definitions/canonicalArtifact" },
    "contract": { "$ref": "c_artifact_common.schema.json#/definitions/commandContract" },
    "site_profile": { "type": ["object", "null"] },
    "rule_profile": { "type": ["object", "null"] },
    "documents": {
      "type": "array",
      "items": {
        "$ref": "c_artifact_common.schema.json#/definitions/documentEntry"
      }
    }
  },
  "additionalProperties": true
}
