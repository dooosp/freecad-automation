{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dooosp.github.io/freecad-automation/schemas/quality_linkage.schema.json",
  "title": "Quality Linkage",
  "allOf": [
    {
      "$ref": "d_artifact_common.schema.json#/$defs/rootArtifact"
    }
  ],
  "type": "object",
  "required": [
    "artifact_type",
    "schema_version",
    "analysis_version",
    "generated_at",
    "part_id",
    "revision",
    "warnings",
    "coverage",
    "confidence",
    "source_artifact_refs",
    "summary",
    "records"
  ],
  "properties": {
    "artifact_type": {
      "const": "quality_linkage"
    },
    "summary": {
      "type": "object",
      "required": [
        "issue_count",
        "matched_categories"
      ],
      "properties": {
        "issue_count": {
          "type": "integer",
          "minimum": 0
        },
        "matched_categories": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": true
    },
    "records": {
      "type": "array",
      "items": {
        "$ref": "d_artifact_common.schema.json#/$defs/qualityLinkRecord"
      }
    }
  },
  "unevaluatedProperties": false
}
