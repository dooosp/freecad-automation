{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dooosp.github.io/freecad-automation/schemas/review_priorities.schema.json",
  "title": "Review Priorities",
  "allOf": [
    {
      "$ref": "d_artifact_common.schema.json#/$defs/rootArtifact"
    }
  ],
  "type": "object",
  "required": [
    "artifact_type",
    "schema_version",
    "analysis_version",
    "generated_at",
    "part_id",
    "revision",
    "warnings",
    "coverage",
    "confidence",
    "source_artifact_refs",
    "records",
    "recommended_actions"
  ],
  "properties": {
    "artifact_type": {
      "const": "review_priorities"
    },
    "records": {
      "type": "array",
      "items": {
        "$ref": "d_artifact_common.schema.json#/$defs/reviewPriorityRecord"
      }
    },
    "recommended_actions": {
      "type": "array",
      "items": {
        "$ref": "d_artifact_common.schema.json#/$defs/recommendedAction"
      }
    }
  },
  "unevaluatedProperties": false
}
