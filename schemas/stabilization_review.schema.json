{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://dooosp.github.io/freecad-automation/schemas/stabilization_review.schema.json",
  "title": "Canonical Launch Stabilization Review",
  "type": "object",
  "required": [
    "schema_version",
    "artifact_type",
    "generated_at",
    "agent",
    "part",
    "summary",
    "warnings",
    "coverage",
    "confidence",
    "source_artifact_refs",
    "canonical_artifact",
    "contract"
  ],
  "properties": {
    "schema_version": { "const": "1.0" },
    "artifact_type": { "const": "stabilization_review" },
    "generated_at": { "type": "string" },
    "agent": { "const": "stabilization_review" },
    "part": { "$ref": "c_artifact_common.schema.json#/definitions/partIdentity" },
    "summary": { "type": "object" },
    "warnings": { "$ref": "c_artifact_common.schema.json#/definitions/warningList" },
    "coverage": { "$ref": "c_artifact_common.schema.json#/definitions/coverageSummary" },
    "confidence": { "$ref": "c_artifact_common.schema.json#/definitions/confidenceSummary" },
    "source_artifact_refs": { "$ref": "c_artifact_common.schema.json#/definitions/sourceArtifactRefs" },
    "canonical_artifact": { "$ref": "c_artifact_common.schema.json#/definitions/canonicalArtifact" },
    "contract": { "$ref": "c_artifact_common.schema.json#/definitions/commandContract" },
    "analysis_basis": { "type": "object" },
    "comparison_basis": { "type": "object" },
    "baseline": { "type": "object" },
    "candidate": { "type": "object" },
    "readiness_deltas": { "type": "object" },
    "change_reasons": { "type": "array", "items": { "type": "object" } },
    "recommended_action_changes": { "type": "object" },
    "warning_changes": { "type": "object" },
    "station_runtime_review": { "type": "array", "items": { "type": "object" } },
    "launch_instability_signals": { "type": "array", "items": { "type": "string" } },
    "likely_root_causes": { "type": "array", "items": { "type": "string" } },
    "improvement_candidates": { "type": "array", "items": { "type": "string" } },
    "quality_traceability_watchpoints": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": true
}
