{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dooosp.github.io/freecad-automation/schemas/manufacturing_hotspots.schema.json",
  "title": "Manufacturing Hotspots",
  "allOf": [
    {
      "$ref": "d_artifact_common.schema.json#/$defs/rootArtifact"
    }
  ],
  "type": "object",
  "required": [
    "artifact_type",
    "schema_version",
    "analysis_version",
    "generated_at",
    "part_id",
    "revision",
    "warnings",
    "coverage",
    "confidence",
    "source_artifact_refs",
    "part",
    "hotspots"
  ],
  "properties": {
    "artifact_type": {
      "const": "manufacturing_hotspots"
    },
    "part": {
      "$ref": "d_artifact_common.schema.json#/$defs/partSummary"
    },
    "bootstrap": {
      "type": "object",
      "properties": {
        "import_diagnostics": {
          "type": "object"
        },
        "bootstrap_summary": {
          "type": "object"
        },
        "confidence_map": {
          "type": "object"
        },
        "warnings": {
          "$ref": "d_artifact_common.schema.json#/$defs/warningList"
        }
      },
      "additionalProperties": true
    },
    "hotspots": {
      "type": "array",
      "items": {
        "$ref": "d_artifact_common.schema.json#/$defs/hotspotRecord"
      }
    }
  },
  "unevaluatedProperties": false
}
