{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://dooosp.github.io/freecad-automation/schemas/standard_docs_manifest.schema.json",
  "title": "Standard Docs Manifest",
  "type": "object",
  "required": ["schema_version", "workflow", "generated_at", "draft_notice", "part", "documents"],
  "properties": {
    "schema_version": { "type": "string" },
    "workflow": { "const": "standard_docs_generation" },
    "generated_at": { "type": "string" },
    "draft_notice": { "type": "string" },
    "part": { "type": "object" },
    "documents": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["filename", "path"],
        "properties": {
          "filename": { "type": "string" },
          "path": { "type": "string" }
        }
      }
    }
  },
  "additionalProperties": true
}
