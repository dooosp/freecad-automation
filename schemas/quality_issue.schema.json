{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://dooosp.github.io/freecad-automation/schemas/quality_issue.schema.json",
  "title": "Quality Issue",
  "type": "object",
  "required": ["issue_id", "description"],
  "properties": {
    "issue_id": { "type": "string" },
    "defect_code": { "type": ["string", "null"] },
    "defect_class": { "type": ["string", "null"] },
    "description": { "type": "string" },
    "severity": { "type": ["string", "null"] },
    "status": { "type": ["string", "null"] },
    "location_hint": { "type": ["string", "null"] },
    "feature_hint": { "type": ["string", "null"] },
    "process_step": { "type": ["string", "null"] },
    "occurrence_count": { "type": ["integer", "null"] },
    "quantity": { "type": ["integer", "null"] },
    "source_row": { "type": ["integer", "null"] }
  },
  "additionalProperties": true
}
