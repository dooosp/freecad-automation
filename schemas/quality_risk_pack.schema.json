{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://dooosp.github.io/freecad-automation/schemas/quality_risk_pack.schema.json",
  "title": "Quality Risk Pack",
  "type": "object",
  "required": ["schema_version", "agent", "part", "summary", "quality_risks", "quality_gates"],
  "properties": {
    "schema_version": { "type": "string" },
    "agent": { "const": "quality_traceability" },
    "part": { "type": "object" },
    "summary": { "type": "object" },
    "critical_dimensions": { "type": "array", "items": { "type": "object" } },
    "inspection_required_points": { "type": "array", "items": { "type": "object" } },
    "traceability_summary": { "type": "object" },
    "quality_risks": { "type": "array", "items": { "type": "object" } },
    "quality_gates": { "type": "array", "items": { "type": "object" } },
    "evidence_pack": { "type": "object" }
  },
  "additionalProperties": true
}
