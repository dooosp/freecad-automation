{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "feature-identity.schema.json",
  "title": "Feature Identity",
  "type": "object",
  "required": ["schema_version", "source", "features"],
  "properties": {
    "schema_version": { "type": "string" },
    "source": {
      "type": "object",
      "required": ["path", "kind"],
      "properties": {
        "path": { "type": "string" },
        "kind": { "type": "string" }
      },
      "additionalProperties": true
    },
    "features": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "label", "confidence"],
        "properties": {
          "id": { "type": "string" },
          "label": { "type": "string" },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "notes": { "type": "string" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
