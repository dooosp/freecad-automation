{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://freecad-automation.local/schemas/output-manifest.schema.json",
  "title": "FreeCAD Automation Output Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "command",
    "command_args",
    "input",
    "repo",
    "runtime",
    "timings",
    "outputs",
    "linked_artifacts",
    "warnings",
    "errors",
    "status"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "command": {
      "type": "string",
      "minLength": 1
    },
    "command_args": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "input": {
      "$ref": "#/$defs/fileRecord"
    },
    "repo": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "root",
        "branch",
        "head_sha",
        "dirty_at_start"
      ],
      "properties": {
        "root": {
          "type": "string",
          "minLength": 1
        },
        "branch": {
          "type": [
            "string",
            "null"
          ]
        },
        "head_sha": {
          "type": [
            "string",
            "null"
          ]
        },
        "dirty_at_start": {
          "type": "boolean"
        }
      }
    },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "node_version",
        "platform",
        "freecad_available",
        "freecad_version"
      ],
      "properties": {
        "node_version": {
          "type": "string",
          "minLength": 1
        },
        "platform": {
          "type": "string",
          "minLength": 1
        },
        "freecad_available": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "freecad_version": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "timings": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "started_at",
        "finished_at",
        "duration_ms"
      ],
      "properties": {
        "started_at": {
          "type": [
            "string",
            "null"
          ]
        },
        "finished_at": {
          "type": [
            "string",
            "null"
          ]
        },
        "duration_ms": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        }
      }
    },
    "outputs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/outputRecord"
      }
    },
    "linked_artifacts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "qa_json",
        "run_log_json",
        "traceability_json",
        "report_pdf",
        "quality_json"
      ],
      "properties": {
        "qa_json": {
          "type": [
            "string",
            "null"
          ]
        },
        "run_log_json": {
          "type": [
            "string",
            "null"
          ]
        },
        "traceability_json": {
          "type": [
            "string",
            "null"
          ]
        },
        "report_pdf": {
          "type": [
            "string",
            "null"
          ]
        },
        "quality_json": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "errors": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "status": {
      "enum": [
        "pass",
        "warning",
        "fail",
        "unknown"
      ]
    }
  },
  "$defs": {
    "fileRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "sha256",
        "size_bytes"
      ],
      "properties": {
        "path": {
          "type": [
            "string",
            "null"
          ]
        },
        "sha256": {
          "type": [
            "string",
            "null"
          ]
        },
        "size_bytes": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        }
      }
    },
    "outputRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "kind",
        "exists",
        "size_bytes",
        "sha256"
      ],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "type": "string",
          "minLength": 1
        },
        "exists": {
          "type": "boolean"
        },
        "size_bytes": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "sha256": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    }
  }
}
