{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dooosp.github.io/freecad-automation/schemas/inspection-evidence.schema.json",
  "title": "Inspection Evidence",
  "description": "Contract for genuine manufacturing inspection evidence. Generated CAD, drawing, DFM, readiness, or review artifacts do not satisfy this contract by themselves.",
  "type": "object",
  "required": [
    "schema_version",
    "evidence_type",
    "source_type",
    "measured_features",
    "overall_result"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "evidence_type": {
      "const": "inspection_evidence"
    },
    "source_type": {
      "enum": [
        "cmm_report",
        "manual_caliper_check",
        "go_no_go_gauge",
        "first_article_inspection",
        "supplier_inspection_report",
        "other_inspection_source"
      ]
    },
    "inspected_part": {
      "type": "string",
      "minLength": 1
    },
    "package_id": {
      "type": "string",
      "minLength": 1
    },
    "inspected_at": {
      "type": "string",
      "minLength": 1
    },
    "inspection_date": {
      "type": "string",
      "minLength": 1
    },
    "inspector": {
      "type": [
        "string",
        "null"
      ]
    },
    "inspection_author": {
      "type": [
        "string",
        "null"
      ]
    },
    "measurement_system": {
      "enum": [
        "metric",
        "imperial",
        "mixed",
        "unknown"
      ]
    },
    "units": {
      "type": "string",
      "minLength": 1
    },
    "measured_features": {
      "type": "array",
      "minItems": 1,
      "contains": {
        "type": "object",
        "required": [
          "measured_value"
        ]
      },
      "items": {
        "$ref": "#/$defs/measuredFeature"
      }
    },
    "overall_result": {
      "enum": [
        "pass",
        "fail",
        "partial",
        "unknown"
      ]
    },
    "source_ref": {
      "$ref": "#/$defs/safeRelativePath"
    },
    "source_file": {
      "$ref": "#/$defs/safeRelativePath"
    },
    "traceability_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "notes": {
      "type": [
        "string",
        "null"
      ]
    }
  },
  "anyOf": [
    {
      "required": [
        "inspected_part"
      ]
    },
    {
      "required": [
        "package_id"
      ]
    }
  ],
  "allOf": [
    {
      "anyOf": [
        {
          "required": [
            "inspected_at"
          ]
        },
        {
          "required": [
            "inspection_date"
          ]
        }
      ]
    },
    {
      "anyOf": [
        {
          "required": [
            "measurement_system"
          ]
        },
        {
          "required": [
            "units"
          ]
        }
      ]
    },
    {
      "anyOf": [
        {
          "required": [
            "source_ref"
          ]
        },
        {
          "required": [
            "source_file"
          ]
        }
      ]
    }
  ],
  "$defs": {
    "safeRelativePath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?![A-Za-z]:)(?!.*\\\\)(?!.*(?:^|/)\\.\\.(?:/|$))(?!output(?:/|$))(?!tmp/codex(?:/|$)).+$"
    },
    "measuredFeature": {
      "type": "object",
      "required": [
        "feature_id",
        "result",
        "measurement_method"
      ],
      "properties": {
        "feature_id": {
          "type": "string",
          "minLength": 1
        },
        "drawing_ref": {
          "type": [
            "string",
            "null"
          ]
        },
        "requirement_ref": {
          "type": [
            "string",
            "null"
          ]
        },
        "nominal_value": {
          "type": [
            "number",
            "string",
            "null"
          ]
        },
        "measured_value": {
          "type": [
            "number",
            "string",
            "boolean"
          ]
        },
        "tolerance_upper": {
          "type": [
            "number",
            "null"
          ]
        },
        "tolerance_lower": {
          "type": [
            "number",
            "null"
          ]
        },
        "allowed_range": {
          "type": [
            "object",
            "null"
          ],
          "properties": {
            "min": {
              "type": [
                "number",
                "null"
              ]
            },
            "max": {
              "type": [
                "number",
                "null"
              ]
            }
          },
          "additionalProperties": true
        },
        "units": {
          "type": [
            "string",
            "null"
          ]
        },
        "result": {
          "enum": [
            "pass",
            "fail",
            "not_measured"
          ]
        },
        "measurement_method": {
          "type": "string",
          "minLength": 1
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "result": {
                "enum": [
                  "pass",
                  "fail"
                ]
              }
            },
            "required": [
              "result"
            ]
          },
          "then": {
            "required": [
              "measured_value"
            ]
          }
        }
      ],
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
