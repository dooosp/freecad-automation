{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://freecad-automation.local/schemas/report-summary.schema.json",
  "title": "Engineering report decision summary",
  "type": "object",
  "required": [
    "schema_version",
    "command",
    "input_config",
    "report_pdf",
    "overall_status",
    "overall_score",
    "ready_for_manufacturing_review",
    "config_name",
    "generated_at",
    "inputs_consumed",
    "artifacts_referenced",
    "blocking_issues",
    "warnings",
    "recommended_actions",
    "missing_optional_artifacts",
    "top_risks"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "command": { "const": "report" },
    "input_config": { "type": ["string", "null"] },
    "report_pdf": { "type": ["string", "null"] },
    "report_summary_json": { "type": ["string", "null"] },
    "overall_status": {
      "type": "string",
      "enum": ["pass", "warning", "fail", "incomplete"]
    },
    "overall_score": { "type": ["number", "null"] },
    "ready_for_manufacturing_review": { "type": ["boolean", "null"] },
    "config_name": { "type": "string" },
    "run_id": { "type": ["string", "null"] },
    "git_commit": { "type": ["string", "null"] },
    "git_branch": { "type": ["string", "null"] },
    "generated_at": { "type": "string" },
    "runtime_status": {
      "type": "object",
      "required": ["mode", "available"],
      "properties": {
        "mode": { "type": ["string", "null"] },
        "available": { "type": "boolean" }
      },
      "additionalProperties": true
    },
    "inputs_consumed": {
      "type": "array",
      "items": { "$ref": "#/$defs/artifactRef" }
    },
    "artifacts_referenced": {
      "type": "array",
      "items": { "$ref": "#/$defs/artifactRef" }
    },
    "blocking_issues": {
      "type": "array",
      "items": { "type": "string" }
    },
    "warnings": {
      "type": "array",
      "items": { "type": "string" }
    },
    "recommended_actions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "missing_optional_artifacts": {
      "type": "array",
      "items": { "type": "string" }
    },
    "top_risks": {
      "type": "array",
      "items": { "type": "string" }
    },
    "drawing_intent": { "$ref": "#/$defs/drawingIntent" },
    "feature_catalog": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "available",
        "total_features",
        "recognized_features",
        "unknown_features",
        "recognition_policy"
      ],
      "properties": {
        "path": { "type": "string" },
        "available": { "type": "boolean" },
        "total_features": { "type": "integer", "minimum": 0 },
        "recognized_features": { "type": "integer", "minimum": 0 },
        "unknown_features": { "type": "integer", "minimum": 0 },
        "recognition_policy": { "type": ["string", "null"] }
      }
    },
    "surfaces": {
      "type": "object",
      "properties": {
        "create_quality": { "$ref": "#/$defs/surfaceSummary" },
        "drawing_quality": { "$ref": "#/$defs/surfaceSummary" },
        "dfm": { "$ref": "#/$defs/surfaceSummary" },
        "fem": { "$ref": "#/$defs/surfaceSummary" },
        "tolerance": { "$ref": "#/$defs/surfaceSummary" }
      },
      "additionalProperties": false
    }
  },
  "$defs": {
    "artifactRef": {
      "type": "object",
      "required": ["key", "label", "status", "path"],
      "properties": {
        "key": { "type": "string" },
        "label": { "type": "string" },
        "path": { "type": ["string", "null"] },
        "required": { "type": "boolean" },
        "status": {
          "type": "string",
          "enum": ["available", "generated", "in_memory", "not_available", "not_run"]
        },
        "note": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },
    "surfaceSummary": {
      "type": "object",
      "required": ["status", "available", "blocking_issues", "warnings"],
      "properties": {
        "status": { "type": "string" },
        "available": { "type": "boolean" },
        "score": { "type": ["number", "null"] },
        "blocking_issues": {
          "type": "array",
          "items": { "type": "string" }
        },
        "warnings": {
          "type": "array",
          "items": { "type": "string" }
        },
        "semantic_quality": { "$ref": "#/$defs/drawingSemanticQuality" }
      },
      "additionalProperties": true
    },
    "drawingSemanticQuality": {
      "type": "object",
      "required": [
        "decision",
        "advisory_decision",
        "enforceable",
        "score",
        "critical_features_total",
        "critical_features_covered",
        "required_dimensions_total",
        "required_dimensions_present",
        "missing_required_dimensions",
        "required_notes_missing",
        "required_views_missing",
        "traceability",
        "missing_critical_information",
        "required_blockers",
        "optional_missing_information",
        "suggested_actions",
        "extracted_evidence"
      ],
      "properties": {
        "decision": { "type": "string" },
        "advisory_decision": { "type": "string" },
        "enforceable": { "type": "boolean" },
        "score": { "type": ["number", "null"] },
        "critical_features_total": { "type": "integer", "minimum": 0 },
        "critical_features_covered": { "type": "integer", "minimum": 0 },
        "required_dimensions_total": { "type": "integer", "minimum": 0 },
        "required_dimensions_present": { "type": "integer", "minimum": 0 },
        "missing_required_dimensions": {
          "type": "array",
          "items": { "type": "string" }
        },
        "required_notes_missing": {
          "type": "array",
          "items": { "type": "string" }
        },
        "required_views_missing": {
          "type": "array",
          "items": { "type": "string" }
        },
        "traceability": {
          "type": "object",
          "required": [
            "required_dimensions_total",
            "linked_required_dimensions",
            "missing_required_dimensions",
            "unknown_required_dimensions"
          ],
          "properties": {
            "required_dimensions_total": { "type": "integer", "minimum": 0 },
            "linked_required_dimensions": { "type": "integer", "minimum": 0 },
            "missing_required_dimensions": {
              "type": "array",
              "items": { "type": "string" }
            },
            "unknown_required_dimensions": {
              "type": "array",
              "items": { "type": "string" }
            }
          },
          "additionalProperties": true
        },
        "missing_critical_information": {
          "type": "array",
          "items": { "type": "string" }
        },
        "required_blockers": {
          "type": "array",
          "items": { "type": "string" }
        },
        "optional_missing_information": {
          "type": "array",
          "items": { "type": "string" }
        },
        "suggested_actions": {
          "type": "array",
          "items": { "type": "string" }
        },
        "extracted_evidence": {
          "type": "object",
          "required": [
            "status",
            "advisory_only",
            "path",
            "matched_required_dimensions",
            "matched_required_notes",
            "matched_required_views",
            "unknowns",
            "limitations"
          ],
          "properties": {
            "status": { "type": "string" },
            "advisory_only": { "type": "boolean" },
            "file": { "type": ["string", "null"] },
            "path": { "type": ["string", "null"] },
            "sources": {
              "type": "array",
              "items": { "type": "object", "additionalProperties": true }
            },
            "coverage": {
              "type": "object",
              "additionalProperties": true
            },
            "required_dimensions": {
              "type": "array",
              "items": { "type": "object", "additionalProperties": true }
            },
            "required_notes": {
              "type": "array",
              "items": { "type": "object", "additionalProperties": true }
            },
            "required_views": {
              "type": "array",
              "items": { "type": "object", "additionalProperties": true }
            },
            "unmatched_dimensions": {
              "type": "array",
              "items": { "type": "object", "additionalProperties": true }
            },
            "unmatched_notes": {
              "type": "array",
              "items": { "type": "object", "additionalProperties": true }
            },
            "matched_required_dimensions": { "type": "integer", "minimum": 0 },
            "matched_required_notes": { "type": "integer", "minimum": 0 },
            "matched_required_views": { "type": "integer", "minimum": 0 },
            "missing_required_items": {
              "type": "array",
              "items": { "type": "string" }
            },
            "unknowns": {
              "type": "array",
              "items": { "type": "string" }
            },
            "limitations": {
              "type": "array",
              "items": { "type": "string" }
            },
            "suggested_actions": {
              "type": "array",
              "items": { "type": "string" }
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "drawingIntent": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "part_type": { "type": "string" },
        "manufacturing_process": { "type": "string" },
        "material": { "type": "string" },
        "critical_features": {
          "type": "array",
          "items": { "type": "object", "additionalProperties": true }
        },
        "required_dimensions": {
          "type": "array",
          "items": { "type": "object", "additionalProperties": true }
        },
        "required_notes": {
          "type": "array",
          "items": {
            "anyOf": [
              { "type": "string" },
              { "type": "object", "additionalProperties": true }
            ]
          }
        },
        "datum_strategy": {
          "type": "object",
          "additionalProperties": true
        },
        "required_views": {
          "type": "array",
          "items": {
            "anyOf": [
              { "type": "string" },
              { "type": "object", "additionalProperties": true }
            ]
          }
        },
        "drawing_standard": {
          "anyOf": [
            { "type": "string" },
            { "type": "object", "additionalProperties": true }
          ]
        },
        "tolerance_policy": {
          "anyOf": [
            { "type": "string" },
            { "type": "object", "additionalProperties": true }
          ]
        },
        "missing_semantics_policy": {
          "type": "string",
          "enum": ["advisory", "enforced"]
        }
      }
    }
  },
  "additionalProperties": false
}
