{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://dooosp.github.io/freecad-automation/schemas/process_plan.schema.json",
  "title": "Process Plan",
  "type": "object",
  "required": ["schema_version", "agent", "part", "summary", "process_flow"],
  "properties": {
    "schema_version": { "type": "string" },
    "agent": { "const": "process_planning" },
    "part": { "type": "object" },
    "summary": { "type": "object" },
    "planning_basis": { "type": "object" },
    "process_flow": { "type": "array", "items": { "type": "object" } },
    "key_inspection_points": { "type": "array", "items": { "type": "object" } },
    "automation_candidates": { "type": "array", "items": { "type": "string" } },
    "bottleneck_risks": { "type": "array", "items": { "type": "string" } },
    "planning_notes": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": true
}
