{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://dooosp.github.io/freecad-automation/schemas/process_plan.schema.json",
  "title": "Canonical Process Plan",
  "type": "object",
  "required": [
    "schema_version",
    "artifact_type",
    "generated_at",
    "agent",
    "part",
    "summary",
    "process_flow",
    "warnings",
    "coverage",
    "confidence",
    "source_artifact_refs",
    "canonical_artifact",
    "contract"
  ],
  "properties": {
    "schema_version": { "const": "1.0" },
    "artifact_type": { "const": "process_plan" },
    "generated_at": { "type": "string" },
    "agent": { "const": "process_planning" },
    "part": { "$ref": "c_artifact_common.schema.json#/definitions/partIdentity" },
    "summary": { "type": "object" },
    "warnings": { "$ref": "c_artifact_common.schema.json#/definitions/warningList" },
    "coverage": { "$ref": "c_artifact_common.schema.json#/definitions/coverageSummary" },
    "confidence": { "$ref": "c_artifact_common.schema.json#/definitions/confidenceSummary" },
    "source_artifact_refs": { "$ref": "c_artifact_common.schema.json#/definitions/sourceArtifactRefs" },
    "canonical_artifact": { "$ref": "c_artifact_common.schema.json#/definitions/canonicalArtifact" },
    "contract": { "$ref": "c_artifact_common.schema.json#/definitions/commandContract" },
    "planning_basis": { "type": "object" },
    "process_flow": { "type": "array", "items": { "type": "object" } },
    "key_inspection_points": { "type": "array", "items": { "type": "object" } },
    "automation_candidates": { "type": "array", "items": { "type": "string" } },
    "bottleneck_risks": { "type": "array", "items": { "type": "string" } },
    "planning_notes": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": true
}
